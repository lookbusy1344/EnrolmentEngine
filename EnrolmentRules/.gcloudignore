# What `gcloud run deploy --source .` uploads to Cloud Build, which then runs the
# Dockerfile over the uploaded tree (so .dockerignore still applies on top of this).
#
# This file must EXIST, even though it largely mirrors .dockerignore. Without it gcloud
# auto-generates one from .gitignore, and .gitignore lists .sourcerevision — the file that
# carries the commit hash into a build that cannot reach git (see Directory.Build.props'
# StampGitCommit). Auto-generation would therefore drop the very file the build needs and
# silently stamp every deploy as "unknown". Keep .sourcerevision unlisted here.

# Build output and caches — rebuilt inside the image.
**/bin/
**/obj/
BenchmarkDotNet.Artifacts/

# LibMan-restored client libs (gitignored; restored during the build).
src/EnrolmentRules.Web/wwwroot/lib/

# Vite-built Vue bundle (gitignored; rebuilt from ClientApp/ during the build).
src/EnrolmentRules.Web/wwwroot/app/

# ClientApp build/test artefacts and caches — regenerated by `pnpm install`/`pnpm build`.
# package.json, pnpm-lock.yaml, vite.config.ts, tsconfig*.json, and src/**/public/** are
# NOT ignored — the BuildClientApp MSBuild target needs them in the build context.
src/EnrolmentRules.Web/ClientApp/node_modules/
src/EnrolmentRules.Web/ClientApp/dist/
src/EnrolmentRules.Web/ClientApp/coverage/
src/EnrolmentRules.Web/ClientApp/.vite/
src/EnrolmentRules.Web/ClientApp/test-results/
src/EnrolmentRules.Web/ClientApp/playwright-report/

# Not needed to build/run the web app; keeps the upload small.
tests/
docs/
examples/
scripts/

# IDE / OS / VCS noise.
.github/
.idea/
.vs/
.vscode/
.cursor/
**/*.user
**/.DS_Store
