{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://enrolmentrules/qualifications.schema.json",
  "title": "Qualification scale",
  "description": "Structural validation for the typed qualification scale data file. Complete qualification-type coverage is enforced at the production load boundary; duplicate and ordinal checks are enforced in code.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "qualifications"
  ],
  "properties": {
    "qualifications": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/type_entry"
      }
    }
  },
  "$defs": {
    "qualification_type": {
      "type": "string",
      "enum": [
        "a_level",
        "btec_extended_certificate",
        "btec_diploma",
        "nvq"
      ]
    },
    "grade_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "grade",
        "ordinal",
        "equivalence"
      ],
      "properties": {
        "grade": {
          "type": "string",
          "minLength": 1
        },
        "ordinal": {
          "type": "integer",
          "minimum": 0
        },
        "equivalence": {
          "type": "number",
          "minimum": 0,
          "maximum": 6
        }
      }
    },
    "type_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "grades"
      ],
      "properties": {
        "type": {
          "$ref": "#/$defs/qualification_type"
        },
        "grades": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/grade_entry"
          }
        }
      }
    }
  }
}
