{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://enrolmentrules/thresholds.schema.json",
  "title": "Policy thresholds",
  "description": "Runtime policy knobs for eligibility and subject entry thresholds.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "pass_grade",
    "min_passes",
    "top_entry",
    "strong_entry",
    "standard_entry",
    "further_maths_average_entry",
    "humanities_average_entry",
    "min_dfe_green_probability_at_or_above",
    "min_dfe_amber_probability_at_or_above",
    "adult_age",
    "amber_tariff_factor"
  ],
  "properties": {
    "pass_grade": {
      "type": "integer",
      "minimum": 1,
      "maximum": 9
    },
    "min_passes": {
      "type": "integer",
      "minimum": 1
    },
    "top_entry": {
      "type": "integer",
      "minimum": 1,
      "maximum": 9
    },
    "strong_entry": {
      "type": "integer",
      "minimum": 1,
      "maximum": 9
    },
    "standard_entry": {
      "type": "integer",
      "minimum": 1,
      "maximum": 9
    },
    "further_maths_average_entry": {
      "type": "number",
      "minimum": 0,
      "maximum": 9
    },
    "humanities_average_entry": {
      "type": "number",
      "minimum": 0,
      "maximum": 9
    },
    "min_dfe_green_probability_at_or_above": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "min_dfe_amber_probability_at_or_above": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "adult_age": {
      "type": "integer",
      "minimum": 1
    },
    "max_green_choices": {
      "description": "Optional, normally omitted. When set, caps the number of auto-enrol greens and demotes the lowest-weight surplus to amber. Omit to disable the cap so every green stays green.",
      "type": "integer",
      "minimum": 1
    },
    "amber_tariff_factor": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  }
}
