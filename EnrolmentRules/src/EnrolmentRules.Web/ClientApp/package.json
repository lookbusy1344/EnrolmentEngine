{
  "name": "clientapp",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@11.16.0",
  "scripts": {
    "dev": "vite",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "check:no-js-source": "node scripts/check-no-js-source.mjs",
    "typecheck": "vue-tsc -b",
    "test": "vitest run",
    "build": "vue-tsc -b && vite build",
    "build:watch": "vite build --watch",
    "preview": "vite preview",
    "e2e": "playwright test",
    "verify": "pnpm lint && pnpm format:check && pnpm check:no-js-source && pnpm typecheck && pnpm test && pnpm build"
  },
  "dependencies": {
    "vue": "^3.5.40"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "@vitejs/plugin-vue": "^6.0.8",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.7.0",
    "eslint-plugin-vue": "^10.10.0",
    "globals": "^17.7.0",
    "jiti": "^2.7.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.6",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.65.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10",
    "vue-tsc": "^3.3.7"
  }
}
